# ─────────────────────────────────────────────────────────────────────────────
# Your Humble EquityBot — Environment Variables
# Copy this file to .env and fill in your keys.
# Keys marked FREE require free registration (5 minutes).
# Keys marked PAID are optional — only needed if free sources fall short.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI Providers (needed to generate reports) ─────────────────────────────────
ANTHROPIC_API_KEY=your_claude_api_key_here          # claude.ai → API keys
OPENAI_API_KEY=your_openai_api_key_here             # platform.openai.com → API keys

# ── Tier 1: Free, no key needed (yfinance, SEC EDGAR) ────────────────────────
# Nothing to configure — works out of the box.

# ── Tier 2: Free with registration ───────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your_key_here   # FREE — register at alphavantage.co (25 calls/day)
FRED_API_KEY=your_key_here            # FREE — register at fred.stlouisfed.org

# ── Tier 4: Paid fallback (optional — only if free sources are insufficient) ──
FMP_API_KEY=your_key_here             # PAID ~$14/mo — financialmodelingprep.com
EODHD_API_KEY=your_key_here          # PAID ~$19/mo — eodhd.com

# ── Active LLM provider ───────────────────────────────────────────────────────
LLM_PROVIDER=claude                   # "claude" or "openai"
LLM_MODEL=claude-sonnet-4-5           # claude-sonnet-4-5 | gpt-4o
ADVERSARIAL_MODE=false                # "true" to run both models + cross-review
