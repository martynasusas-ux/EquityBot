# Streamlit Community Cloud — Secrets Manager template.
# Copy this content into your app's Secrets panel at share.streamlit.io
# (Settings → Secrets). Do NOT commit the real secrets.toml file to git.

# ── API keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY       = "sk-ant-..."
OPENAI_API_KEY          = "sk-proj-..."
ALPHA_VANTAGE_API_KEY   = "your_key_here"
FRED_API_KEY            = "your_key_here"
FMP_API_KEY             = ""
EODHD_API_KEY           = ""

LLM_PROVIDER            = "claude"
LLM_MODEL               = "claude-sonnet-4-5"
ADVERSARIAL_MODE        = "false"

# ── Access control ────────────────────────────────────────────────────────────
# Add one entry per allowed user: username = sha256(password)
# Generate a hash: python -c "import hashlib; print(hashlib.sha256('your_password'.encode()).hexdigest())"
# Remove this [users] section entirely to disable the login gate (local dev).
[users]
alice = "sha256_hash_of_alices_password_here"
bob   = "sha256_hash_of_bobs_password_here"
